{
  "manifest_version": 3,
  "name": "Jean find my Job",
  "short_name": "Jean",
  "version": "0.5.0",
  "description": "Ton coach de candidature directement sur LinkedIn, France Travail et Welcome to the Jungle.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Jean find my Job",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://kjsqfgpewjzierlxzdyj.supabase.co/*",
    "https://jeanfindmyjob.fr/*",
    "https://candidat.francetravail.fr/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://candidat.francetravail.fr/offres/recherche/detail/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}