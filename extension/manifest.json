{
  "manifest_version": 3,
  "name": "Jean find my Job",
  "short_name": "Jean",
  "version": "0.9.9",
  "description": "Capture des offres, analyse ton CV et suis tes candidatures, sans quitter ton jobboard.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "https://kjsqfgpewjzierlxzdyj.supabase.co/*",
    "https://jeanfindmyjob.fr/*",
    "https://candidat.francetravail.fr/*",
    "https://www.welcometothejungle.com/*",
    "https://www.linkedin.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://candidat.francetravail.fr/*"],
      "js": [
        "content/scrapers/francetravail.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.welcometothejungle.com/*"],
      "js": [
        "content/scrapers/welcometothejungle.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": [
        "content/scrapers/linkedin.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}